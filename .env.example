# ── Telegram API credentials (get at https://my.telegram.org/apps) ──
TELEGRAM_API_ID=12345
TELEGRAM_API_HASH=your_telegram_api_hash_here
TELEGRAM_PHONE=+8613800138000
# Channel to listen to — username (with @) or ID; leave blank for all dialogs
TELEGRAM_CHANNEL=@ychan_signal

# ── Binance Futures API credentials ────────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
# Set to false when you are ready for live trading
BINANCE_TESTNET=true

# ── Trading parameters ─────────────────────────────────────────────
RISK_PER_TRADE=0.02       # 每笔风险比例（2%）
STOP_LOSS_PCT=0.02        # 止损比例（2%）
TAKE_PROFIT_PCT=0.04      # 止盈比例（4%），风险收益比 1:2
LEVERAGE=5

# ── Technical analysis (K线 + 指标) ────────────────────────────────
ANALYSIS_TIMEFRAME=4h              # 主趋势K线周期 4h/1h/15m
ANALYSIS_EMA_FAST=20               # 快线EMA周期
ANALYSIS_EMA_SLOW=50               # 慢线EMA周期
ANALYSIS_RSI_PERIOD=14             # RSI计算周期
ANALYSIS_RSI_OVERSOLD=35.0         # RSI超卖阈值（低于此值视为超卖适合入场）
ANALYSIS_RSI_OVERBOUGHT=55.0       # RSI超买阈值（高于此值视为超买等回调）
ANALYSIS_MAX_DEVIATION_PCT=5.0     # 价格偏离EMA20的最大容忍百分比
LIMIT_ORDER_TIMEOUT=7200           # 限价单超时取消（秒）
LIMIT_ORDER_CHECK_INTERVAL=30

# ── Market regime filter (市场状态分类) ──────────────────────────
ANALYSIS_ADX_THRESHOLD=25.0           # ADX阈值（高于此值视为趋势行情）
ANALYSIS_VOLATILE_ATR_RATIO=1.5       # ATR比值阈值（高于此值视为高波动）

# ── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Leave empty to log to stderr only
LOG_FILE=
